# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5433/hirectl
DATABASE_SYNC_URL=postgresql://postgres:password@localhost:5433/hirectl
SQL_ECHO=false
DB_POOL_SIZE=4
DB_MAX_OVERFLOW=4
DB_POOL_TIMEOUT_SECONDS=15
DB_POOL_RECYCLE_SECONDS=1800

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── AI providers (use one or both) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# AI provider: "anthropic" | "openai" | "ollama"
AI_PROVIDER=ollama
AI_MODEL=llama3.2:1b

# Ollama (local or Docker, zero cost) — fallback when no API keys
# Local CLI use: http://localhost:11434
# Docker Compose API/scheduler override this to http://ollama:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT_SECONDS=8
AI_FAILURE_COOLDOWN_SECONDS=120
AI_BRIEF_REFRESH_MIN_SCORE=65
AI_BRIEF_REFRESH_MAX_AGE_HOURS=24
AI_BRIEF_REFRESH_BATCH_SIZE=8

# ─── GitHub ──────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...

# ─── Email (Resend) ──────────────────────────────────────────────
RESEND_API_KEY=re_...
ALERT_EMAIL_FROM=hirectl@yourdomain.com
ALERT_EMAIL_TO=you@email.com

# ─── Data sources ────────────────────────────────────────────────
CRUNCHBASE_API_KEY=       # optional — funding data
SEC_USER_AGENT=Hirectl/0.1 your-name your-email@example.com
SEC_FORM_D_ENABLED=true
YC_JOBS_ENABLED=true
WELLFOUND_ENABLED=true
CAREER_PAGE_RENDERER=http
HTTP_TIMEOUT_SECONDS=20
HTTP_MAX_CONNECTIONS=20
HTTP_MAX_KEEPALIVE_CONNECTIONS=10
JOB_BOARD_BATCH_SIZE=4
CAREER_PAGE_BATCH_SIZE=3
CAREER_PAGE_BATCH_DELAY_SECONDS=1.0

# ─── App ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
APSCHEDULER_LOG_LEVEL=WARNING
ENVIRONMENT=development
SCHEDULER_TIMEZONE=America/Chicago
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001
FRONTEND_ORIGIN_REGEX=https://.*\\.vercel\\.app
AUTOMATION_WATCHLIST_MIN_SCORE=72
AUTOMATION_WATCHLIST_MIN_SIGNALS_30D=1
AUTOMATION_WATCHLIST_MIN_ROLES=1
AUTOMATION_OUTREACH_MIN_SCORE=84
AUTOMATION_OUTREACH_FOLLOW_UP_DAYS=3
AUTOMATION_OUTREACH_CONTACT_ROLE=engineering lead
AUTOMATION_STALE_WATCHLIST_DAYS=14
AUTOMATION_STALE_WATCHLIST_MAX_SCORE=60
AUTOMATION_STALE_WATCHLIST_MAX_SIGNALS_30D=0
AUTOMATION_STALE_WATCHLIST_MAX_ROLES=0

# Score weights (0.0–1.0, must sum to 1.0)
SCORE_WEIGHT_FIT=0.60
SCORE_WEIGHT_URGENCY=0.40

# Ingest schedule (cron expressions)
CRON_JOB_BOARDS=0 */4 * * *
CRON_FUNDING=*/30 * * * *
CRON_GITHUB=0 * * * *
CRON_CAREER_PAGES=0 */6 * * *
CRON_MODEL_REFRESH=35 1 * * *
CRON_BRIEF_REFRESH=*/20 * * * *
CRON_DAILY_DIGEST=0 7 * * *
SCHEDULER_RUN_ON_STARTUP=false
SCHEDULER_JOB_MAX_INSTANCES=1
SCHEDULER_JOB_COALESCE=true
SCHEDULER_JOB_MISFIRE_GRACE_SECONDS=300
